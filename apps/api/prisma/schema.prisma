generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BullSex {
  MALE
  FEMALE
  UNKNOWN
}

enum FeedType {
  hay
  compound_feed
}

model Bull {
  id            String         @id @default(cuid())
  userId        String
  tagNumber     String
  name          String?
  birthDate     DateTime
  breed         String?
  sex           BullSex
  arrivalDate   DateTime
  initialWeight Decimal        @db.Decimal(8, 2)
  photoUrl      String?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightRecords WeightRecord[]

  @@unique([userId, tagNumber])
  @@index([userId])
  @@index([tagNumber])
  @@index([createdAt])
}

model WeightRecord {
  id        String   @id @default(cuid())
  bullId    String
  date      DateTime
  weight    Decimal  @db.Decimal(8, 2)
  comment   String?
  createdAt DateTime @default(now())
  bull      Bull     @relation(fields: [bullId], references: [id], onDelete: Cascade)

  @@index([bullId, date])
}

model FeedStock {
  id                         String   @id @default(cuid())
  userId                     String
  type                       FeedType
  currentStockKg             Decimal  @db.Decimal(10, 2)
  consumptionPerBullPerDayKg Decimal  @db.Decimal(8, 3)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  emailVerifiedAt         DateTime?
  passwordHash            String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  sessions                AuthSession[]
  emailVerificationTokens EmailVerificationToken[]
  bulls                   Bull[]
  feedStocks              FeedStock[]
}

model AuthSession {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
