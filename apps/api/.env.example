PORT=3000
# Prisma/PostgreSQL connection for the API.
DATABASE_URL="postgresql://bulki:bulki@localhost:5432/bulki_bull?schema=public"
# Session lifetime after login.
AUTH_SESSION_TTL_DAYS=30
# Base URL used in email verification links.
API_PUBLIC_URL=http://localhost:3000
# Verification token lifetime in minutes.
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440

# If SMTP is not configured, verification links are printed to the API log in dev mode.
# Supported presets: gmail, yandex, mailru.
# You can also leave SMTP_PROVIDER empty and set SMTP_HOST/SMTP_PORT/SMTP_SECURE manually.
SMTP_PROVIDER=
# Use the same address as SMTP_USER when possible to avoid delivery issues.
EMAIL_FROM="Bulki Bull <your-address@example.com>"
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
